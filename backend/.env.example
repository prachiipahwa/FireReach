# FireReach Backend Environment Variables
# Copy this file to .env and fill in your keys

# Groq API for LLM reasoning (llama-3.3-70b-versatile)
# Leave as "mock" to bypass external calls and use dummy fallback text
GROQ_API_KEY=mock

# Tavily API for Signal Harvesting
# Leave as "mock" to use static mock signals
TAVILY_API_KEY=mock

# SendGrid API for Email Deployment
# Leave as "mock" to mock delivery payload without sending emails
SENDGRID_API_KEY=mock

# Email associated with your SendGrid Domain Auth
SENDER_EMAIL=noreply@firereach.example

# Optional Settings
PROJECT_NAME="FireReach AI Outbound Engine"
API_V1_STR="/api/v1"
